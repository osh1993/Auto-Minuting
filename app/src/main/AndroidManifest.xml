<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BLE 퍼미션 (API 31+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />

    <!-- MediaStore 오디오 파일 접근 (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- MediaStore 파일 접근 폴백 (API 32 이하) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 배터리 최적화 무시 요청 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 네트워크 (Cloud API 폴백 + SDK) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 알림 (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <queries>
        <!-- NotebookLM 앱 설치 확인용 (Android 11+ 패키지 가시성) -->
        <package android:name="com.google.android.apps.labs.language.tailwind" />
    </queries>

    <application
        android:name=".AutoMinutingApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AutoMinuting">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AutoMinuting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 삼성 녹음앱 등 외부 앱에서 공유 수신 (텍스트 + 파일 + 다중) -->
        <activity
            android:name=".presentation.share.ShareReceiverActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- WorkManager 기본 초기화 비활성화 (Application에서 HiltWorkerFactory로 커스텀 초기화) -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- 오디오 수집 Foreground Service (connectedDevice 타입: BLE 연결 유지) -->
        <service
            android:name=".service.AudioCollectionService"
            android:foregroundServiceType="connectedDevice"
            android:exported="false" />

        <!-- 파이프라인 알림 액션 처리 (회의록 생성/공유) -->
        <receiver
            android:name=".receiver.PipelineActionReceiver"
            android:exported="false" />

        <!-- 삼성 녹음앱 감지 스파이크 Foreground Service (specialUse: 파일 모니터링) -->
        <service
            android:name=".spike.SpikeService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- 삼성 녹음앱 감지 스파이크 로그 UI -->
        <activity
            android:name=".spike.SpikeLogActivity"
            android:exported="false"
            android:theme="@style/Theme.AutoMinuting" />

    </application>

</manifest>
